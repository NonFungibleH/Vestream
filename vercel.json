{
  "crons": [
    {
      "path": "/api/cron/seed-cache",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/seed-cache?mode=deep",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/tvl-snapshot",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/notify",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
