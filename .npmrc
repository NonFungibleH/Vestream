# Use legacy peer-dep resolution because RainbowKit 2.2.8 declares
# `wagmi: ^2.9.0` as a peer dep but we have wagmi 3.6.4 installed.
# Wagmi's v3 line is API-compatible with v2 (different versioning history,
# same WagmiProvider/createConfig surface), so the peer-dep mismatch is
# cosmetic. Local `npm install` is lenient by default; Vercel + GitHub
# Actions both use stricter resolution and reject the install without this.
#
# Long-term fix: align wagmi to a v2.x version that RainbowKit accepts
# explicitly. Short-term: this makes CI green.
legacy-peer-deps=true
